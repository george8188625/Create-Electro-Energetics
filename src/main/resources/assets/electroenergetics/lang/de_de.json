  "electroenergetics.ponder.switch.header": "Schalter verwenden",
  "electroenergetics.ponder.switch.text_1": "Schalter können verwendet werden um einen Stromfluss zu unterbrechen.",

  "electroenergetics.ponder.tag.electric_train_sound_changing": "Elektrozug Klang-Modifikatoren",
  "electroenergetics.ponder.tag.electric_train_sound_changing.description": "Diese Blöcke können den Klang von Elektrozügen verändern.",
  "electroenergetics.ponder.tag.electrical": "Elektrische Bauteile",
  "electroenergetics.ponder.tag.electrical.description": "Bauteile, welche Elektrizität verwenden.",
  "electroenergetics.ponder.tag.electricity_basics": "Elektrische Grundlagen",
  "electroenergetics.ponder.tag.electricity_basics.description": "Wie Elektrizität funktioniert.",

  "electroenergetics.ponder.third_rail.header": "Stromschienen verwenden",
  "electroenergetics.ponder.third_rail.text_1": "Elektrische Züge können auch über eine Stromschiene mit Strom versorgt werden.",
  "electroenergetics.ponder.third_rail.text_2": "Dafür benutzt man einen Stromschuh.",

  "electroenergetics.ponder.transformer.header": "Spannungen wandeln.",
  "electroenergetics.ponder.transformer.text_1": "Transformatoren können verwendet werden, um Spannungen zu verändern",
  "electroenergetics.ponder.transformer.text_2": "Setze einfach das Verhältnis",

  "electroenergetics.ponder.transformer_core_multiblock.header": "Transformatorkern-Grundlagen",
  "electroenergetics.ponder.transformer_core_multiblock.text_1": "Transformatorkerne können mit einer bestimmten Anzahl an Windungen konfiguriert werden.",
  "electroenergetics.ponder.transformer_core_multiblock.text_2": "Wenn man Transformatorkerne mit Radiatorpaneelen umgibt oder sie waterlogged, wird ihre Leistungsfähigkeit erhöht.",
  "electroenergetics.ponder.transformer_core_multiblock.text_3": "Ein Überschreiten der Leistungsfähigkeit eines Transformatorkerns, führt zu einer Überlast,",

  "electroenergetics.ponder.transformer_losses.header": "Transformatoren und Leistungsverluste",
  "electroenergetics.ponder.transformer_losses.text_1": "Drähte haben einen geringen Widerstand, dadurch entsteht ein Energieverlust",
  "electroenergetics.ponder.transformer_losses.text_2": "299.5V",
  "electroenergetics.ponder.transformer_losses.text_3": "299.4V",
  "electroenergetics.ponder.transformer_losses.text_4": "10A",
  "electroenergetics.ponder.transformer_losses.text_5": "Energieverluste sind proportional zum Widerstand und dem Quadrat der Stromstärke.",
  "electroenergetics.ponder.transformer_losses.text_6": "Transformatoren können verwendet werden, um die Spannung zu erhöhen und dadurch die Stromstärke zu verringern.",
  "electroenergetics.ponder.transformer_losses.text_7": "3.3A",
  "electroenergetics.ponder.transformer_losses.text_8": "Für lange Stromleitungen kann ein Erhöhen der Spannung die Leistungsverluste deutlich senken.",

  "electroenergetics.ponder.transformer_turns.header": "Wie Transformatoren funktionieren.",
  "electroenergetics.ponder.transformer_turns.text_1": "Transformatoren werden verwendet um die Spannung hoch- oder runterzustufen. ",
  "electroenergetics.ponder.transformer_turns.text_2": "Beachte wie das Windungsverhältnis und das Spannungsverhältnis gleich sind.",
  "electroenergetics.ponder.transformer_turns.text_3": "Der Transformator verbindet die beiden Schaltkreise zudem nicht.",
  "electroenergetics.ponder.transformer_turns.text_4": "Sondern, sie werden magnetisch verbunden.",

  "electroenergetics.ponder.voltage_introduction.header": "Was ist Spannung?",
  "electroenergetics.ponder.voltage_introduction.text_1": "Spannung ist das Maß des Unterschieds des elektrischen Potentials.",
  "electroenergetics.ponder.voltage_introduction.text_2": "Das Voltmeter misst den Unterschied zwischen den beiden Punkten.",
  "electroenergetics.ponder.voltage_introduction.text_3": "Beachte, dass hier noch kein Strom fließt!",
  "electroenergetics.ponder.voltage_introduction.text_4": "Denk dir Spannung wie den Druck, der eine Strömung verursacht.",
  "electroenergetics.ponder.voltage_introduction.text_5": "Aktuell wird keine Energie bewegt, da zwar Spannung anliegt, aber kein Stromfluss stattfindet.",
  "electroenergetics.ponder.voltage_introduction.text_6": "Sobald eine Last angeschlossen wird, beginnt der Strom zu fließen.",
  "electroenergetics.ponder.voltage_introduction.text_7": "Je höher die Spannung, desto höher ist auch die Stromstärke.",

  "electroenergetics.ponder.wire_attachments.header": "Drahtzusätze",
  "electroenergetics.ponder.wire_attachments.text_1": "Bestimmte Gegenstände können auf Drähten aufgehangen werden.",

