  "electroenergetics.ponder.switch.text_1": "开关可以用来切断电流",
  "electroenergetics.ponder.tag.electric_train_sound_changing": "改变电车的声音",
  "electroenergetics.ponder.tag.electric_train_sound_changing.description": "这些方块会改变电车的声音。",
  "electroenergetics.ponder.tag.electrical": "电力设备",
  "electroenergetics.ponder.tag.electrical.description": "使用电力的设备",
