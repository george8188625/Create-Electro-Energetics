  "electroenergetics.ponder.basics.header": "ʎʇıɔıɹʇɔǝןǝ buıpuɐʇsɹǝpun oʇ ɥɔɐoɹddɐ ǝʌıʇınʇuı uⱯ",
  "electroenergetics.ponder.basics.text_1": "˙dooן ɐ uı pǝʇɔǝuuoɔ ǝɹıʍ ɐ ǝuıbɐɯI",
  "electroenergetics.ponder.basics.text_10": "˙ʍoןb ʇı sǝʞɐɯ ʇɐǝɥ ǝɥʇ 'ʇuǝɯɐןıɟ s,qןnq ǝɥʇ dn sʇɐǝɥ ʇuǝɯǝʌoɯ sıɥʇ 'ǝsɐɔ sıɥʇ uI",
  "electroenergetics.ponder.basics.text_11": "˙sʇop buıobʇno ɟo ɹǝqɯnu ǝɥʇ oʇ ןɐnbǝ sı sʇop buıɯoɔuı ɟo ɹǝqɯnu ǝɥʇ ʍoɥ ǝɔıʇoN",
  "electroenergetics.ponder.basics.text_12": "˙ʍɐꞀ ʇuǝɹɹnƆ s,ɟɟoɥɥɔɹıʞ ɟo uoıʇıuıɟǝp ǝɥʇ sı sıɥ⟘",
  "electroenergetics.ponder.basics.text_2": "˙suoɹʇɔǝןǝ sɐ ɯǝɥʇ ɟo ʞuıɥ⟘ ˙ǝɹıʍ sıɥʇ uo pǝɔɐןd ǝɹɐ sʇop ǝןʇʇıꞀ",
  "electroenergetics.ponder.basics.text_3": "˙ɹǝɥʇo ɥɔɐǝ ɯoɹɟ ʎɐʍɐ ǝʌoɯ ʇ,uɐɔ ʎǝɥʇ ʇnq 'ǝʌoɯ uɐɔ sʇop ǝsǝɥ⟘ ˙uıɐɥɔ ɐ ǝʞıן sʇI",
  "electroenergetics.ponder.basics.text_4": "˙ɹǝɥʇo ǝɥʇ oʇ ɥsnd puɐ 'ǝpıs ǝuo ɯoɹɟ ןןnd oʇ ʎɹʇ ʎǝɥ⟘ ˙uıɐɥɔ sıɥʇ ǝʌoɯ oʇ ʎɹʇ sǝɔɹnos ǝbɐʇןoΛ",
  "electroenergetics.ponder.basics.text_5": "˙ʎbɹǝuǝ sı ʇuǝɯǝʌoɯ ɹıǝɥʇ 'sǝʌןǝsɯǝɥʇ ʎbɹǝuǝ ʇuǝsǝɹdǝɹ ʇ,uop sʇop ǝsǝɥ⟘ ˙ʇuɐʇsuoɔ ʎɐʇs sʇop ǝsǝɥʇ ɟo ɹǝqɯnu ǝɥʇ ʍoɥ ǝɔıʇoN",
  "electroenergetics.ponder.basics.text_6": "˙ʇınɔɹıɔ ʇɹoɥs ɐ ʎןןɐnʇɔɐ sı sıɥ⟘",
  "electroenergetics.ponder.basics.text_7": "¡ʇsɐɟ ʎןןɐǝɹ sʇop ǝsǝɥʇ ǝʌoɯ oʇ ǝןqɐ sı ǝɔɹnos ǝbɐʇןoʌ ǝɥʇ puɐ 'ǝɔuɐʇsısǝɹ ou sı ǝɹǝɥ⟘",
  "electroenergetics.ponder.basics.text_8": "˙pɐǝʇsuı ǝɔıʌǝp ɐ ɥbnoɹɥʇ ʇı ʇɔǝuuoƆ",
  "electroenergetics.ponder.basics.text_9": "˙ʎbɹǝuǝ sɐ sʇop ǝsǝɥʇ ɟo ʇuǝɯǝʌoɯ ǝɥʇ ǝsn sǝɔıʌǝᗡ",
  "electroenergetics.ponder.connectors.header": "sǝɹıM buıʇɔǝuuoƆ",
  "electroenergetics.ponder.connectors.text_1": "˙ʎʇıɔıɹʇɔǝןǝ ʎɐןǝɹ oʇ pǝsn ǝq uɐɔ sǝɹıM puɐ sɹoʇɔǝuuoƆ",
  "electroenergetics.ponder.connectors.text_2": "˙ןoods ʎʇdɯǝ uɐ ǝsn 'sǝɹıʍ buıʇsıxǝ ǝʌoɯǝɹ o⟘",
  "electroenergetics.ponder.connectors.text_3": "˙pǝʎp ǝq uɐɔ sǝɹıʍ pǝʇɐןnsuI",
  "electroenergetics.ponder.connectors_chunks.header": "sʞunɥƆ pǝpɐoןun ɥbnoɹɥʇ sǝɹıM",
  "electroenergetics.ponder.connectors_chunks.text_1": "˙sʞunɥɔ pǝpɐoן ɟo ǝpısʇno ןɐuoıʇɔunɟ sʎɐʇs ʎʇıɔıɹʇɔǝןƎ",
  "electroenergetics.ponder.diodes.header": "ʇuǝɹɹnɔ ɟo uoıʇɔǝɹıp ǝɥʇ buıןןoɹʇuoƆ",
  "electroenergetics.ponder.diodes.text_1": "ʇuǝɹɹnɔ ɟo uoıʇɔǝɹıp ǝɥʇ ןoɹʇuoɔ oʇ pǝsn ǝq uɐɔ sǝpoıᗡ",
  "electroenergetics.ponder.diodes.text_2": "˙˙˙ ןɐıʇuǝʇod ɹǝɥbıɥ ǝɥʇ oʇ pǝʇɔǝuuoɔ sı ǝpouɐ ǝɥʇ ɟı 'ʍoןɟ oʇ ʇuǝɹɹnɔ ʍoןןɐ ןןıʍ sǝpoıᗡ",
  "electroenergetics.ponder.diodes.text_3": "ןɐıʇuǝʇod ɹǝʍoן ǝɥʇ oʇ pǝʇɔǝuuoɔ sı ǝpoɥʇɐɔ ǝɥʇ puɐ ˙˙˙",
  "electroenergetics.ponder.diodes.text_4": "sɐıᗺ pɹɐʍɹoℲ pǝןןɐɔ s,ʇɐɥ⟘",
  "electroenergetics.ponder.diodes.text_5": "ʍoןɟ ʇuǝɹɹnɔ sʞɔoןq ǝpoıp ǝɥʇ 'ǝsıʍɹǝɥʇO",
  "electroenergetics.ponder.diodes.text_6": "sɐıᗺ ǝsɹǝʌǝᴚ pǝןןɐɔ s,ʇɐɥ⟘",
  "electroenergetics.ponder.railway_electrification.header": "suıɐɹ⟘ buıʎɟıɹʇɔǝןƎ",
  "electroenergetics.ponder.railway_electrification.text_1": "sʞɔoןq ǝʞıן-ǝןod ʎqɹɐǝu oʇ ʇɔǝuuoɔ ʎןןɐɔıʇɐɯoʇnɐ ןןıʍ sɹǝpןoH ʎɹɐuǝʇɐƆ",
  "electroenergetics.ponder.railway_electrification.text_2": "suıɐɹʇ ɹǝʍod oʇ pǝsn ǝq uɐɔ ɯǝʇsʎs ʎɹɐuǝʇɐɔ Ɐ",
