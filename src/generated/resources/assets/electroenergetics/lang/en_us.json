  "electroenergetics.ponder.switch.header": "Using a switch",
  "electroenergetics.ponder.switch.text_1": "Switches can be used to interrupt the flow of current",
  "electroenergetics.ponder.tag.electric_train_sound_changing": "Electric Train Sound Changers",
  "electroenergetics.ponder.tag.electric_train_sound_changing.description": "These blocks change electric train sounds.",
  "electroenergetics.ponder.tag.electrical": "Electrical Components",
  "electroenergetics.ponder.tag.electrical.description": "Components that use electricity",
  "electroenergetics.ponder.tag.electricity_basics": "Electricity Basics",
  "electroenergetics.ponder.tag.electricity_basics.description": "How electricity works",
  "electroenergetics.ponder.third_rail.header": "Using third rail",
  "electroenergetics.ponder.third_rail.text_1": "Electric trains can collect power from a third rail",
  "electroenergetics.ponder.third_rail.text_2": "For that, use a Rail Contact Shoe",
  "electroenergetics.ponder.transformer.header": "Changing voltages",
  "electroenergetics.ponder.transformer.text_1": "Transformers can be used to change voltage.",
  "electroenergetics.ponder.transformer.text_2": "Simply set the ratio.",
  "electroenergetics.ponder.transformer_core_multiblock.header": "Transformer Core Basics",
  "electroenergetics.ponder.transformer_core_multiblock.text_1": "Transformer cores can be configured with a specific number of turns.",
  "electroenergetics.ponder.transformer_core_multiblock.text_2": "Surrounding transformer core with radiator panels or waterlogging them increases its power rating.",
  "electroenergetics.ponder.transformer_core_multiblock.text_3": "Exceeding the transformer's power rating will cause it to overload.",
  "electroenergetics.ponder.transformer_losses.header": "Transformers and energy losses",
  "electroenergetics.ponder.transformer_losses.text_1": "Wires have some resistance, therefore they cause energy losses.",
  "electroenergetics.ponder.transformer_losses.text_2": "299.5V",
  "electroenergetics.ponder.transformer_losses.text_3": "299.4V",
  "electroenergetics.ponder.transformer_losses.text_4": "10A",
  "electroenergetics.ponder.transformer_losses.text_5": "Energy losses are directly proportional to the resistance and the square of the amperage.",
  "electroenergetics.ponder.transformer_losses.text_6": "Transformers can be used to increase the voltage, therefore decrease the amperage.",
  "electroenergetics.ponder.transformer_losses.text_7": "3.3A",
  "electroenergetics.ponder.transformer_losses.text_8": "For large transmission lines, stepping-up the voltage can greatly decrease energy losses.",
  "electroenergetics.ponder.transformer_turns.header": "How transformers work",
  "electroenergetics.ponder.transformer_turns.text_1": "Transformers are used to step-up or step-down voltage",
  "electroenergetics.ponder.transformer_turns.text_2": "Notice how the turns ratio is equal to the voltage ratio",
  "electroenergetics.ponder.transformer_turns.text_3": "Additionally, the transformer doesn't connect the both circuits",
  "electroenergetics.ponder.transformer_turns.text_4": "Instead, it couples them magnetically",
  "electroenergetics.ponder.voltage_introduction.header": "What is voltage?",
  "electroenergetics.ponder.voltage_introduction.text_1": "Voltage is the measurement of difference of electric potential",
  "electroenergetics.ponder.voltage_introduction.text_2": "The voltmeter measures the voltage difference between the two points.",
  "electroenergetics.ponder.voltage_introduction.text_3": "Keep in mind there is no current flow yet!",
  "electroenergetics.ponder.voltage_introduction.text_4": "Think of voltage as the pressure driving current flow.",
  "electroenergetics.ponder.voltage_introduction.text_5": "Currently, no energy is being moved, since there is no current flow.",
  "electroenergetics.ponder.voltage_introduction.text_6": "After connecting a load to the circuit, current starts flowing",
  "electroenergetics.ponder.voltage_introduction.text_7": "The higher the voltage, the more current flows",
